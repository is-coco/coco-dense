{
  "name": "coco-dense",
  "version": "0.4.5",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac dmg zip",
    "dist:mac:dir": "electron-builder --mac dir",
    "dist:win": "electron-builder --win nsis",
    "dist:local": "powershell -ExecutionPolicy Bypass -File build-local.ps1",
    "dist:unpacked": "powershell -ExecutionPolicy Bypass -File build-unpacked.ps1",
    "icon:mac": "bash scripts/make-mac-icon.sh"
  },
  "devDependencies": {
    "electron": "^34.1.0",
    "electron-builder": "^24.13.3",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "pinyin-pro": "^3.28.1"
  },
  "build": {
    "appId": "com.coco.cocodense",
    "productName": "Coco Dense",
    "compression": "store",
    "files": [
      "index.html",
      "styles.css",
      "script.js",
      "main.js",
      "preload.js",
      "assets/**/*",
      "README.md"
    ],
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "win": {
      "icon": "assets/app-icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "mac": {
      "icon": "assets/app-icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "assets/app-icon.ico",
      "uninstallerIcon": "assets/app-icon.ico",
      "installerHeaderIcon": "assets/app-icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Coco Dense",
      "include": "installer.nsh",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "directories": {
      "output": "dist"
    }
  }
}
